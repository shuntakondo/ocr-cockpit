# ─────────────────────────────────────────────────────────────────────────────
# OCR Cockpit — environment configuration
# Copy to `.env` and fill in only what you need. The defaults run end-to-end with
# ZERO external services (mock extraction + in-process PGlite Postgres).
# `.env` is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Leave DATABASE_URL unset to use the bundled in-process Postgres (PGlite),
# persisted to ./.pglite — no server, no install required.
# Set it to point at a real Postgres server (the BFF switches drivers automatically):
# DATABASE_URL=postgres://user:password@localhost:5432/ocr_cockpit

# ── Extraction provider ───────────────────────────────────────────────────────
# One of: mock | ollama | azure        (default: mock)
EXTRACTION_PROVIDER=mock

# ── Ollama (local, free) ──────────────────────────────────────────────────────
# Used when EXTRACTION_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
# A vision model (preferred): the image is sent directly.
#   ollama pull llama3.2-vision   (or minicpm-v, llava)
# A text model (fallback): documents are OCR'd with tesseract.js first, then
# structured by the text model. Works with the llama3.2 you already have.
OLLAMA_MODEL=llama3.2
# Set to "vision" to send images to a multimodal model, or "text" to OCR-then-structure.
OLLAMA_MODE=text

# ── Azure AI Document Intelligence (cloud) ────────────────────────────────────
# Used when EXTRACTION_PROVIDER=azure. Uses the prebuilt invoice/receipt models,
# which return field-level confidence scores natively.
# AZURE_DI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
# AZURE_DI_KEY=<your-key>
# Prebuilt model id: prebuilt-invoice | prebuilt-receipt
AZURE_DI_MODEL=prebuilt-invoice
