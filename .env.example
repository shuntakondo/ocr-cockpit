# ─────────────────────────────────────────────────────────────────────────────
# OCR Cockpit — environment configuration
# Copy to `.env` and fill in only what you need. The defaults run end-to-end with
# ZERO external services (mock extraction + in-process PGlite Postgres).
# `.env` is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Leave DATABASE_URL unset to use the bundled in-process Postgres (PGlite),
# persisted to ./.pglite — no server, no install required.
# Set it to point at a real Postgres server (the BFF switches drivers automatically):
# DATABASE_URL=postgres://user:password@localhost:5432/ocr_cockpit

# ── Extraction provider ───────────────────────────────────────────────────────
# One of: mock | ollama | azure | gemini | groq   (default: mock)
EXTRACTION_PROVIDER=mock

# ── Ollama (local, free) ──────────────────────────────────────────────────────
# Used when EXTRACTION_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434

# Two modes:
#   vision — send the image to a multimodal model. Best accuracy, understands
#            layout, and reads JAPANESE well. Recommended: `ollama pull qwen2.5vl:7b`
#            (verified 100% on a Japanese 適格請求書). minicpm-v is faster but
#            hallucinates Japanese; llama3.2-vision also works.
#   text   — OCR with tesseract.js, then structure with a text model. No extra
#            download (works with the llama3.2 you have). Good for English; weak on Japanese.
OLLAMA_MODE=vision
OLLAMA_MODEL=qwen2.5vl:7b

# tesseract OCR language(s) for text mode: "eng", "jpn", "jpn+eng".
OCR_LANG=eng

# Vision models are slow to load + run — raise this for large models / big images.
OLLAMA_TIMEOUT_MS=180000
# Images are downscaled to this max dimension before vision inference (fewer
# vision tokens = much faster). Lower = faster, higher = more legible small text.
OLLAMA_MAX_IMAGE_PX=1000

# ── Azure AI Document Intelligence (cloud) ────────────────────────────────────
# Used when EXTRACTION_PROVIDER=azure. Uses the prebuilt invoice/receipt models,
# which return field-level confidence scores natively.
# AZURE_DI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
# AZURE_DI_KEY=<your-key>
# Prebuilt model id: prebuilt-invoice | prebuilt-receipt
AZURE_DI_MODEL=prebuilt-invoice

# ── Gemini (Google, fast, free tier) ──────────────────────────────────────────
# Used when EXTRACTION_PROVIDER=gemini. Reads whole PDFs directly (digital AND
# scanned) and images — typically a few seconds per document.
# Get a free API key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=<your-key>
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=60000

# ── Groq (very fast, free tier, no credit card) ───────────────────────────────
# Used when EXTRACTION_PROVIDER=groq. OpenAI-compatible API; extremely fast.
# Default model (Llama 4 Scout) is multimodal, so images use the vision path.
# Groq does NOT read PDFs natively — PDFs go through OCR/text extraction first,
# so digital (text) PDFs work well; for scanned image-only PDFs prefer gemini.
# Get a free key (no card): https://console.groq.com/keys
# GROQ_API_KEY=<your-key>
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_TIMEOUT_MS=60000
